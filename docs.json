{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpeakLouder",
  "description": "Centrum pomocy SpeakLouder.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "favicon": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png"
  },
  "logo": {
    "light": "/images/logovertical.png",
    "dark": "/images/logovertical.png",
    "href": "https://app.speaklouder.pl"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Otwórz aplikację",
      "href": "https://app.speaklouder.pl"
    },
    "links": []
  },
  "navigation": {
    "languages": [
      {
        "language": "pl",
        "default": true,
        "global": {
          "anchors": [
            {
              "anchor": "Aplikacja",
              "href": "https://app.speaklouder.pl",
              "icon": "arrow-up-right-from-square"
            }
          ]
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "how-it-works",
              "dashboard"
            ]
          },
          {
            "group": "Kampanie",
            "pages": [
              "kampanie/index",
              "kampanie/pierwsze-kroki",
              "kampanie/agent",
              "kampanie/workflow",
              "kampanie/leady",
              "kampanie/aktywnosc",
              "kampanie/numer-telefonu",
              "kampanie/ustawienia"
            ]
          },
          {
            "group": "Konto",
            "pages": [
              "numery-telefonow",
              "integracje",
              "credits",
              "ustawienia-konta"
            ]
          }
        ]
      },
      {
        "language": "en",
        "global": {
          "anchors": [
            {
              "anchor": "Open the app",
              "href": "https://app.speaklouder.ai",
              "icon": "arrow-up-right-from-square"
            }
          ]
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "en/index",
              "en/quickstart",
              "en/how-it-works",
              "en/dashboard"
            ]
          },
          {
            "group": "Campaigns",
            "pages": [
              "en/campaigns/index",
              "en/campaigns/get-started",
              "en/campaigns/agent",
              "en/campaigns/workflow",
              "en/campaigns/source",
              "en/campaigns/leads",
              "en/campaigns/activity",
              "en/campaigns/phone-number",
              "en/campaigns/settings"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "en/phone-numbers",
              "en/integrations",
              "en/wallet",
              "en/account-settings"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/pl",
      "destination": "/"
    },
    {
      "source": "/pl/:slug*",
      "destination": "/:slug*"
    }
  ],
  "footer": {
    "socials": {}
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  }
}
