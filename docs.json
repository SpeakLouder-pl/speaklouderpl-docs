{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpeakLouder",
  "description": "Help center for SpeakLouder.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "favicon": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png"
  },
  "logo": {
    "light": "/images/logovertical.png",
    "dark": "/images/logovertical.png",
    "href": "https://app.speaklouder.pl"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.speaklouder.pl",
          "icon": "arrow-up-right-from-square"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Open app",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "how-it-works"
            ]
          },
          {
            "group": "Daily work",
            "pages": [
              "screen-map",
              "guides/lead-panel",
              "guides/workflow-and-scenario",
              "credits"
            ]
          },
          {
            "group": "Campaign setup",
            "pages": [
              "campaigns/meta-forms",
              "campaigns/static-csv",
              "campaigns/shopify-abandoned-cart",
              "campaigns/dynamic-webhook"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/meta-leads",
              "integrations/make",
              "integrations/gmail"
            ]
          }
        ]
      },
      {
        "language": "pl",
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Otwórz aplikację",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "pl/index",
              "pl/quickstart",
              "pl/how-it-works"
            ]
          },
          {
            "group": "Codzienna praca",
            "pages": [
              "pl/screen-map",
              "pl/guides/panel-leada",
              "pl/guides/workflow-i-scenariusz",
              "pl/credits"
            ]
          },
          {
            "group": "Ustawienie kampanii",
            "pages": [
              "pl/campaigns/meta-forms",
              "pl/campaigns/static-csv",
              "pl/campaigns/shopify-abandoned-cart",
              "pl/campaigns/dynamic-webhook"
            ]
          },
          {
            "group": "Integracje",
            "pages": [
              "pl/integrations/meta-leads",
              "pl/integrations/make",
              "pl/integrations/gmail"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  }
}
