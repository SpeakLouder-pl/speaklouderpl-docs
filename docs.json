{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpeakLouder",
  "description": "Help center for SpeakLouder — AI voice follow-up for leads.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "favicon": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png"
  },
  "logo": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png",
    "href": "https://app.speaklouder.pl"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.speaklouder.pl",
          "icon": "arrow-up-right-from-square"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Open app",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "First steps",
            "pages": ["index", "quickstart", "how-it-works"]
          },
          {
            "group": "Using the app",
            "pages": ["screen-map", "guides/lead-panel", "credits"]
          },
          {
            "group": "Workflow & scenario",
            "pages": ["guides/workflow-and-scenario"]
          },
          {
            "group": "Campaign types",
            "pages": [
              "campaigns/meta-forms",
              "campaigns/static-csv",
              "campaigns/dynamic-webhook",
              "campaigns/shopify-abandoned-cart"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/meta-leads",
              "integrations/gmail",
              "integrations/make"
            ]
          }
        ]
      },
      {
        "language": "pl",
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Otwórz aplikację",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "Pierwsze kroki",
            "pages": ["pl/index", "pl/quickstart", "pl/how-it-works"]
          },
          {
            "group": "Korzystanie z aplikacji",
            "pages": ["pl/screen-map", "pl/guides/panel-leada", "pl/credits"]
          },
          {
            "group": "Workflow i scenariusz",
            "pages": ["pl/guides/workflow-i-scenariusz"]
          },
          {
            "group": "Typy kampanii",
            "pages": [
              "pl/campaigns/meta-forms",
              "pl/campaigns/static-csv",
              "pl/campaigns/dynamic-webhook",
              "pl/campaigns/shopify-abandoned-cart"
            ]
          },
          {
            "group": "Integracje",
            "pages": [
              "pl/integrations/meta-leads",
              "pl/integrations/gmail",
              "pl/integrations/make"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  },
  "contextual": {
    "options": ["copy", "view"]
  }
}
