{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpeakLouder",
  "description": "Centrum pomocy SpeakLouder.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "favicon": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png"
  },
  "logo": {
    "light": "/images/logovertical.png",
    "dark": "/images/logovertical.png",
    "href": "https://app.speaklouder.pl"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Otwórz aplikację",
      "href": "https://app.speaklouder.pl"
    },
    "links": []
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Aplikacja",
          "href": "https://app.speaklouder.pl",
          "icon": "arrow-up-right-from-square"
        }
      ]
    },
    "groups": [
      {
        "group": "Start",
        "pages": [
          "index",
          "quickstart",
          "how-it-works",
          "dashboard"
        ]
      },
      {
        "group": "Kampanie",
        "pages": [
          "kampanie/index",
          "kampanie/pierwsze-kroki",
          "kampanie/agent",
          "kampanie/workflow",
          "kampanie/leady",
          "kampanie/aktywnosc",
          "kampanie/numer-telefonu",
          "kampanie/ustawienia"
        ]
      },
      {
        "group": "Konto",
        "pages": [
          "numery-telefonow",
          "integracje",
          "credits",
          "ustawienia-konta"
        ]
      }
    ]
  },
  "footer": {
    "socials": {}
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  }
}
