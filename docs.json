{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpeakLouder",
  "description": "Centrum pomocy SpeakLouder.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "favicon": {
    "light": "/images/logobox.png",
    "dark": "/images/logobox.png"
  },
  "logo": {
    "light": "/images/logovertical.png",
    "dark": "/images/logovertical.png",
    "href": "https://app.speaklouder.pl"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.speaklouder.pl",
          "icon": "arrow-up-right-from-square"
        }
      ]
    },
    "languages": [
      {
        "language": "pl",
        "default": true,
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Otwórz aplikację",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "how-it-works"
            ]
          },
          {
            "group": "Codzienna praca",
            "pages": [
              "screen-map",
              "guides/panel-leada",
              "guides/workflow-i-scenariusz",
              "credits"
            ]
          },
          {
            "group": "Ustawienie kampanii",
            "pages": [
              "campaigns/meta-forms",
              "campaigns/static-csv",
              "campaigns/shopify-abandoned-cart",
              "campaigns/dynamic-webhook"
            ]
          },
          {
            "group": "Integracje",
            "pages": [
              "integrations/meta-leads",
              "integrations/make",
              "integrations/gmail"
            ]
          }
        ]
      },
      {
        "language": "en",
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Open app",
            "href": "https://app.speaklouder.pl"
          }
        },
        "groups": [
          {
            "group": "Start",
            "pages": [
              "en/index",
              "en/quickstart",
              "en/how-it-works"
            ]
          },
          {
            "group": "Daily work",
            "pages": [
              "en/screen-map",
              "en/guides/lead-panel",
              "en/guides/workflow-and-scenario",
              "en/credits"
            ]
          },
          {
            "group": "Campaign setup",
            "pages": [
              "en/campaigns/meta-forms",
              "en/campaigns/static-csv",
              "en/campaigns/shopify-abandoned-cart",
              "en/campaigns/dynamic-webhook"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "en/integrations/meta-leads",
              "en/integrations/make",
              "en/integrations/gmail"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/pl",
      "destination": "/"
    },
    {
      "source": "/pl/",
      "destination": "/"
    },
    {
      "source": "/pl/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/guides/lead-panel",
      "destination": "/en/guides/lead-panel"
    },
    {
      "source": "/guides/lead-panel/",
      "destination": "/en/guides/lead-panel"
    },
    {
      "source": "/guides/workflow-and-scenario",
      "destination": "/en/guides/workflow-and-scenario"
    },
    {
      "source": "/guides/workflow-and-scenario/",
      "destination": "/en/guides/workflow-and-scenario"
    }
  ],
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  }
}
